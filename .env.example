NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/template_dev

# Auth.js (導入時に使用)
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-32-or-more-random-characters

# LLM / モデル比較
LLM_COMPARE_USE_MOCK=false
LLM_COMPARE_TIMEOUT_MS=30000
# LLM_COMPARE_MOCK_FAIL_MODELS=chatgpt:gpt-5.4-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Azure Container Apps (必要時に設定)
AZURE_CONTAINER_APPS_ENVIRONMENT=
AZURE_CONTAINER_APPS_NAME=
